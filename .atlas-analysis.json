  "keyFeatures": [
    "Interactive map with PostGIS geospatial queries",
    "Mobile apps for iOS and Android with offline support",
    "CSV import system with validation and duplicate detection",
    "Batch processing for large datasets (4000+ records)",
    "Organization management with role-based permissions",
    "AED verification and publication workflow",
    "External data source synchronization",
    "Recovery system for failed imports",
    "Clean Architecture with DDD patterns",
    "Branch-specific database environments"
  ],
  "publicApiSurface": [
    "GET /api/aeds - List published AEDs",
    "GET /api/aeds/[id] - Get AED details",
    "GET /api/deas/nearby - Find nearby AEDs",
    "POST /api/auth/register - User registration",
    "POST /api/auth/login - User authentication",
    "POST /api/import - CSV import with validation",
    "POST /api/admin/deas - Create/update AEDs (admin)",
    "POST /api/admin/data-sources/[id]/sync - Sync external data",
    "GET /api/batch/[id]/status - Batch job status",
    "POST /api/verify/[token] - Email verification"
  ]
